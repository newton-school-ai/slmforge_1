# SLMForge environment variables (copy to .env, never commit)

# Hugging Face token (private models, faster downloads)
HF_TOKEN=

# Optional: Google OAuth (shared-deploy mode; off for localhost)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET_KEY=

# Optional: Slack alerts
SLACK_WEBHOOK_URL=

# Datastore (SQLite default; swap to Postgres for shared deploys)
SLMFORGE_DB_URL=sqlite:///./slmforge.db

# Redis (job queue + WebSocket pub/sub)
REDIS_URL=redis://localhost:6379/0

# Shared GPU host (filled in once Issue 4 ticket is granted)
SLMFORGE_GPU_HOST=

# Optional: LLM-as-judge model id (if you enable judge in eval)
SLMFORGE_JUDGE_MODEL=
